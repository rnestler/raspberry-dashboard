# Automatically cycle through enabled widgets every N seconds.
# TAB also advances the widget and resets this timer.
# widget_cycle_secs = 30

# Snapcast now-playing widget: connects to a Snapcast server and auto-switches
# to the now-playing widget when a stream is playing.
# Only active (and included in the cycle) when this section is present.
[snapcast]
host = "127.0.0.1:1705"

# Daily verse widget: fetches a verse of the day from BibleGateway once per day.
# Only active (and included in the cycle) when this section is present.
[daily_verse]
# BibleGateway translation ID. Defaults to NGU-DE (Neue Genfer Übersetzung).
# Other German options: LUTH1912, HFA, SLT, ELB
# version = "NGU-DE"

# Quotes widget: displays a random quote each time the widget is shown.
# Only active (and included in the cycle) when this section is present.
# Add as many [[quotes.items]] entries as you like.
[[quotes.items]]
text = "The only way to do great work is to love what you do."
source = "Steve Jobs"

[[quotes.items]]
text = "Be the change you wish to see in the world."
source = "Mahatma Gandhi"

[[quotes.items]]
text = "In the middle of every difficulty lies opportunity."
# source is optional — omit it to show just the quote text

[homeassistant]
url = "http://homeassistant.local:8123"
token = "your-long-lived-access-token"
poll_interval_secs = 30

# Plain card (default when sensor_type is omitted)
[[homeassistant.sensors]]
entity_id = "sensor.co2_stube"
label = "CO2 Stube"

[[homeassistant.sensors]]
entity_id = "sensor.co2_homeoffice"
label = "CO2 HomeOffice"

# Gauge display: sensor_type = "gauge" with min, max, and exactly 3 ascending
# threshold values that define the blue/green, green/orange, orange/red zone
# boundaries.
[[homeassistant.sensors]]
entity_id = "sensor.humidity_stube"
label = "RH Stube"
sensor_type = "gauge"
min = 20.0
max = 80.0
thresholds = [30.0, 45.0, 65.0]   # blue<30, green 30-45, orange 45-65, red>65

[[homeassistant.sensors]]
entity_id = "sensor.humidity_homeoffice"
label = "RH HomeOffice"
sensor_type = "gauge"
min = 20.0
max = 80.0
thresholds = [30.0, 45.0, 65.0]

[[homeassistant.sensors]]
entity_id = "sensor.temperature_stube"
label = "T Stube"
sensor_type = "gauge"
min = 15.0
max = 30.0
thresholds = [18.0, 21.0, 25.0]   # blue<18, green 18-21, orange 21-25, red>25

[[homeassistant.sensors]]
entity_id = "sensor.temperature_homeoffice"
label = "T HomeOffice"
sensor_type = "gauge"
min = 15.0
max = 30.0
thresholds = [18.0, 21.0, 25.0]
