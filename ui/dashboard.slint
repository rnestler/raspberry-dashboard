export component Dashboard inherits Window {
    in property <string> current-time: "00:00:00";
    in property <length> time-x: 0px;
    in property <length> time-y: 0px;

    fullscreen: true;
    background: black;

    Text {
        x: root.time-x;
        y: root.time-y;
        text: root.current-time;
        color: white;
        font-size: 64px;
    }
}
