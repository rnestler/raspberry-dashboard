import { ClockWidget } from "clock.slint";
import { NowPlayingWidget } from "nowplaying.slint";
import { HomeAssistantWidget, SensorData } from "homeassistant.slint";
import { DailyVerseWidget } from "dailyverse.slint";
import { QuotesWidget } from "quotes.slint";
import { WeatherWidget, ForecastEntry } from "weather.slint";
export { SensorData, ForecastEntry }

export component Dashboard inherits Window {
    in property <int> current-widget: 0;

    // Clock widget properties
    in property <string> current-time: "00:00";
    in property <length> time-x: 0px;
    in property <length> time-y: 0px;

    // Now-playing widget properties
    in property <string> track-title: "";
    in property <string> track-artist: "";
    in property <string> track-album: "";
    in property <string> connection-status: "disconnected";
    in property <image> art-image;

    // HomeAssistant widget properties
    in property <[SensorData]> sensors;

    // Daily verse widget properties
    in property <string> verse-text: "";
    in property <string> verse-reference: "";
    in property <string> verse-version: "";

    // Quotes widget properties
    in property <string> quote-text: "";
    in property <string> quote-source: "";

    // Weather widget properties
    in property <string> weather-condition-symbol: "";
    in property <string> weather-condition: "";
    in property <string> weather-temp: "";
    in property <string> weather-humidity: "";
    in property <string> weather-wind: "";
    in property <[ForecastEntry]> weather-forecasts;

    callback next-widget();
    callback activate-widget(/* id */ int);
    callback deactivate-widget();
    callback quit();

    background: black;
    forward-focus: focus-scope;

    focus-scope := FocusScope {
        key-pressed(event) => {
            if event.text == Key.Tab {
                root.next-widget();
                return accept;
            }
            if event.text == "q" {
                root.quit();
                return accept;
            }
            return reject;
        }
    }

    if root.current-widget == 0: HomeAssistantWidget {
        current-time: root.current-time;
        sensors: root.sensors;
    }

    if root.current-widget == 1: NowPlayingWidget {
        current-time: root.current-time;
        track-title: root.track-title;
        track-artist: root.track-artist;
        track-album: root.track-album;
        art-image: root.art-image;
        connection-status: root.connection-status;
    }

    if root.current-widget == 2: ClockWidget {
        current-time: root.current-time;
        time-x: root.time-x;
        time-y: root.time-y;
    }

    if root.current-widget == 3: DailyVerseWidget {
        current-time: root.current-time;
        verse-text: root.verse-text;
        verse-reference: root.verse-reference;
        verse-version: root.verse-version;
    }

    if root.current-widget == 4: QuotesWidget {
        current-time: root.current-time;
        quote-text: root.quote-text;
        quote-source: root.quote-source;
    }

    if root.current-widget == 5: WeatherWidget {
        current-time: root.current-time;
        weather-condition-symbol: root.weather-condition-symbol;
        weather-condition: root.weather-condition;
        weather-temp: root.weather-temp;
        weather-humidity: root.weather-humidity;
        weather-wind: root.weather-wind;
        weather-forecasts: root.weather-forecasts;
    }
}
