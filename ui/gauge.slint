// Semicircular (180°) gauge with 4 configurable color zones.
//
// Color zones left → right: blue → green → orange → red.
// The three threshold values define the boundaries between zones.
// Center is at the bottom of the arc area; the arc sweeps left→top→right.

// A single donut-arc slice.  Draws a filled wedge between two angles on
// the outer/inner radii.  All instances must share the same viewBox
// (vw × vh) so Slint doesn't rescale them independently.
component ArcSegment inherits Path {
    in property <float> cx;
    in property <float> cy;
    in property <float> ro;          // outer radius
    in property <float> ri;          // inner radius
    in property <float> vw;          // viewBox width
    in property <float> vh;          // viewBox height
    in property <angle> start-angle; // left edge of the slice  (higher angle)
    in property <angle> end-angle;   // right edge of the slice (lower angle)
    in property <brush> color;

    viewbox-x: 0; viewbox-y: 0;
    viewbox-width: vw; viewbox-height: vh;
    fill: color;
    stroke: transparent;

    // Outer arc: start → end (clockwise on screen)
    MoveTo {
        x: root.cx + root.ro * Math.cos(root.start-angle);
        y: root.cy - root.ro * Math.sin(root.start-angle);
    }
    ArcTo {
        x: root.cx + root.ro * Math.cos(root.end-angle);
        y: root.cy - root.ro * Math.sin(root.end-angle);
        radius-x: root.ro; radius-y: root.ro;
        sweep: true; large-arc: false;
    }
    // Step inward
    LineTo {
        x: root.cx + root.ri * Math.cos(root.end-angle);
        y: root.cy - root.ri * Math.sin(root.end-angle);
    }
    // Inner arc: end → start (counter-clockwise on screen)
    ArcTo {
        x: root.cx + root.ri * Math.cos(root.start-angle);
        y: root.cy - root.ri * Math.sin(root.start-angle);
        radius-x: root.ri; radius-y: root.ri;
        sweep: false; large-arc: false;
    }
    Close {}
}

export component Gauge inherits Rectangle {
    height: 300px;
    in property <string> label: "";
    in property <string> value: "0";
    in property <string> unit: "";
    // Numeric range and thresholds (float)
    in property <float> min-value: 0;
    in property <float> max-value: 100;
    in property <float> current-value: 0;
    in property <float> threshold1: 25;  // blue  / green  boundary
    in property <float> threshold2: 50;  // green / orange boundary
    in property <float> threshold3: 75;  // orange/ red    boundary

    background: #1a1a1a;
    border-radius: 8px;

    VerticalLayout {
        padding: 12px;

        // ── Arc area ─────────────────────────────────────────────────────────
        arc := Rectangle {
            // ── Geometry (all in logical pixels, unitless floats) ─────────────
            property <float> w: self.width / 1px;
            property <float> h: self.height / 1px;
            // Centre of the full circle sits at the bottom-centre of this rect.
            property <float> cx: self.w / 2;
            property <float> cy: self.h;
            property <float> ro: self.h;           // outer radius
            property <float> ri: self.h * 0.55;    // inner radius (donut hole)

            // ── Normalised fractions for each threshold / current value ───────
            property <float> range: (root.max-value - root.min-value) > 0
                ? (root.max-value - root.min-value) : 1.0;
            property <float> f1: Math.clamp((root.threshold1 - root.min-value) / self.range, 0, 1);
            property <float> f2: Math.clamp((root.threshold2 - root.min-value) / self.range, 0, 1);
            property <float> f3: Math.clamp((root.threshold3 - root.min-value) / self.range, 0, 1);
            property <float> fn: Math.clamp((root.current-value - root.min-value) / self.range, 0, 1);

            // ── Angles ───────────────────────────────────────────────────────
            // value=min → π (left), value=max → 0 (right)
            property <angle> a0: 3.14159265rad;
            property <angle> a1: 3.14159265rad * (1.0 - self.f1);
            property <angle> a2: 3.14159265rad * (1.0 - self.f2);
            property <angle> a3: 3.14159265rad * (1.0 - self.f3);
            property <angle> a4: 0rad;
            property <angle> an: 3.14159265rad * (1.0 - self.fn);

            // ── Blue zone (min → threshold1) ─────────────────────────────────
            ArcSegment {
                width: parent.width; height: parent.height;
                cx: arc.cx; cy: arc.cy; ro: arc.ro; ri: arc.ri;
                vw: arc.w; vh: arc.h;
                start-angle: arc.a0; end-angle: arc.a1;
                color: #2196F3;
            }

            // ── Green zone (threshold1 → threshold2) ─────────────────────────
            ArcSegment {
                width: parent.width; height: parent.height;
                cx: arc.cx; cy: arc.cy; ro: arc.ro; ri: arc.ri;
                vw: arc.w; vh: arc.h;
                start-angle: arc.a1; end-angle: arc.a2;
                color: #4CAF50;
            }

            // ── Orange zone (threshold2 → threshold3) ────────────────────────
            ArcSegment {
                width: parent.width; height: parent.height;
                cx: arc.cx; cy: arc.cy; ro: arc.ro; ri: arc.ri;
                vw: arc.w; vh: arc.h;
                start-angle: arc.a2; end-angle: arc.a3;
                color: #FF9800;
            }

            // ── Red zone (threshold3 → max) ──────────────────────────────────
            ArcSegment {
                width: parent.width; height: parent.height;
                cx: arc.cx; cy: arc.cy; ro: arc.ro; ri: arc.ri;
                vw: arc.w; vh: arc.h;
                start-angle: arc.a3; end-angle: arc.a4;
                color: #F44336;
            }

            // ── Needle (in the donut band only, above the value text) ─────────
            Path {
                width: parent.width;
                height: parent.height;
                viewbox-x: 0; viewbox-y: 0;
                viewbox-width: arc.w; viewbox-height: arc.h;
                fill: transparent;
                stroke: white;
                stroke-width: 3px;
                MoveTo {
                    x: arc.cx + arc.ri * Math.cos(arc.an);
                    y: arc.cy - arc.ri * Math.sin(arc.an);
                }
                LineTo {
                    x: arc.cx + arc.ro * 0.9 * Math.cos(arc.an);
                    y: arc.cy - arc.ro * 0.9 * Math.sin(arc.an);
                }
            }

            VerticalLayout {
                height: parent.height * 0.4;
                y: parent.height * 0.6;
                width: parent.width;
                Text {
                    text: root.value + " " + root.unit;
                    color: white;
                    font-size: 28px;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.label;
                    color: #888888;
                    font-size: 26px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
