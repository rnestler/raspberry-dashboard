import { Gauge } from "gauge.slint";

export struct SensorData {
    label: string,
    value: string,
    unit: string,
    // Gauge fields (only meaningful when is-gauge = true)
    is-gauge: bool,
    min-value: float,
    max-value: float,
    current-value: float,
    threshold1: float,
    threshold2: float,
    threshold3: float,
}

// Plain card display (non-gauge sensors)
component SensorCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> unit;

    border-radius: 8px;
    background: #1a1a1a;

    VerticalLayout {
        padding: 20px;
        spacing: 10px;
        alignment: center;

        Text {
            text: root.label;
            color: #888888;
            font-size: 28px;
            horizontal-alignment: center;
        }
        HorizontalLayout {
            alignment: center;
            spacing: 4px;
            Text {
                text: root.value;
                color: white;
                font-size: 48px;
                horizontal-alignment: center;
            }
            Text {
                text: root.unit;
                color: #cccccc;
                font-size: 24px;
                vertical-alignment: bottom;
            }
        }
    }
}

// Switches between Gauge and SensorCard based on sensor.is-gauge
component SensorDisplay inherits Rectangle {
    in property <SensorData> sensor;

    background: transparent;

    if sensor.is-gauge: Gauge {
        width: parent.width;
        height: parent.height;
        label: sensor.label;
        value: sensor.value;
        unit: sensor.unit;
        min-value: sensor.min-value;
        max-value: sensor.max-value;
        current-value: sensor.current-value;
        threshold1: sensor.threshold1;
        threshold2: sensor.threshold2;
        threshold3: sensor.threshold3;
    }

    if !sensor.is-gauge: SensorCard {
        width: parent.width;
        height: parent.height;
        label: sensor.label;
        value: sensor.value;
        unit: sensor.unit;
    }
}

export component HomeAssistantWidget inherits Rectangle {
    in property <string> current-time: "00:00:00";
    in property <[SensorData]> sensors;

    VerticalLayout {
        padding: 40px;

        Text {
            text: root.current-time;
            color: white;
            font-size: 54px;
            horizontal-alignment: center;
        }

        Rectangle { vertical-stretch: 1; }

        if root.sensors.length == 0: Text {
            text: "No sensors configured";
            color: #888888;
            font-size: 32px;
            horizontal-alignment: center;
        }

        GridLayout {
            spacing: 20px;
            padding: 20px;

            for sensor[i] in root.sensors: SensorDisplay {
                row: Math.floor(i / 3);
                col: Math.mod(i, 3);
                sensor: sensor;
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
