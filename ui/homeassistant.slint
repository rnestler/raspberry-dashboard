export struct SensorData {
    label: string,
    value: string,
    unit: string,
}

component SensorCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> unit;

    border-radius: 8px;
    background: #1a1a1a;

    VerticalLayout {
        padding: 16px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.label;
            color: #888888;
            font-size: 20px;
            horizontal-alignment: center;
        }
        HorizontalLayout {
            alignment: center;
            spacing: 4px;
            Text {
                text: root.value;
                color: white;
                font-size: 48px;
                horizontal-alignment: center;
            }
            Text {
                text: root.unit;
                color: #cccccc;
                font-size: 24px;
                vertical-alignment: bottom;
            }
        }
    }
}

export component HomeAssistantWidget inherits Rectangle {
    in property <string> current-time: "00:00:00";
    in property <[SensorData]> sensors;

    VerticalLayout {
        padding: 40px;

        Text {
            text: root.current-time;
            color: white;
            font-size: 48px;
            horizontal-alignment: center;
        }

        Rectangle { vertical-stretch: 1; }

        if root.sensors.length == 0: Text {
            text: "No sensors configured";
            color: #888888;
            font-size: 32px;
            horizontal-alignment: center;
        }

        HorizontalLayout {
            spacing: 20px;
            alignment: center;

            for sensor in root.sensors: SensorCard {
                label: sensor.label;
                value: sensor.value;
                unit: sensor.unit;
                width: 220px;
                height: 120px;
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
